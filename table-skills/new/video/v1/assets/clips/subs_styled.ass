Dialogue: 0,0:00:00.00,0:00:01.54,Default,,0,0,0,,传统影视公司做漫剧
Dialogue: 0,0:00:01.54,0:00:02.77,Default,,0,0,0,,要求学历985
Dialogue: 0,0:00:02.77,0:00:03.69,Default,,0,0,0,,这里面每个字
Dialogue: 0,0:00:03.69,0:00:05.08,Default,,0,0,0,,都透着一种反常识
Dialogue: 0,0:00:05.08,0:00:06.47,Default,,0,0,0,,在绝大多数漫剧公司
Dialogue: 0,0:00:06.47,0:00:07.70,Default,,0,0,0,,把招聘需求放宽到
Dialogue: 0,0:00:07.70,0:00:09.09,Default,,0,0,0,,专科学历的情况下
Dialogue: 0,0:00:09.09,0:00:10.93,Default,,0,0,0,,以苍兰诀、永夜星河闻名的
Dialogue: 0,0:00:10.93,0:00:12.63,Default,,0,0,0,,恒星引力，对AI岗要求
Dialogue: 0,0:00:12.63,0:00:14.17,Default,,0,0,0,,985、211学历
Dialogue: 0,0:00:14.17,0:00:15.71,Default,,0,0,0,,QS100本科以上
Dialogue: 0,0:00:15.71,0:00:17.56,Default,,0,0,0,,连AI漫剧实习生也一样
Dialogue: 0,0:00:17.56,0:00:19.04,Default,,0,0,0,,受到短剧等激烈冲击
Dialogue: 0,0:00:19.04,0:00:20.23,Default,,0,0,0,,传统影视公司以及
Dialogue: 0,0:00:20.23,0:00:21.41,Default,,0,0,0,,经纪或MCN机构
Dialogue: 0,0:00:21.41,0:00:22.60,Default,,0,0,0,,不转型就没饭吃
Dialogue: 0,0:00:22.60,0:00:23.94,Default,,0,0,0,,从13家公司放出的
Dialogue: 0,0:00:23.94,0:00:25.42,Default,,0,0,0,,AI相关招聘职位中
Dialogue: 0,0:00:25.42,0:00:27.05,Default,,0,0,0,,我们能看出什么端倪呢？
Dialogue: 0,0:00:27.05,0:00:28.53,Default,,0,0,0,,娱乐资本论分析发现
Dialogue: 0,0:00:28.53,0:00:30.46,Default,,0,0,0,,华策、正午阳光、启蒙影业等
Dialogue: 0,0:00:30.46,0:00:31.64,Default,,0,0,0,,属于“降本型”
Dialogue: 0,0:00:31.64,0:00:33.28,Default,,0,0,0,,博纳、恒星引力、欢娱、
Dialogue: 0,0:00:33.28,0:00:34.91,Default,,0,0,0,,耀客等属于“增效型”
Dialogue: 0,0:00:34.91,0:00:36.54,Default,,0,0,0,,柠萌等属于“出海型”
Dialogue: 0,0:00:36.54,0:00:37.75,Default,,0,0,0,,乐华、哇唧唧哇等
Dialogue: 0,0:00:37.75,0:00:39.41,Default,,0,0,0,,经纪公司转向AI艺人、
Dialogue: 0,0:00:39.41,0:00:41.23,Default,,0,0,0,,虚拟偶像及AI粉丝运营；
Dialogue: 0,0:00:41.23,0:00:42.44,Default,,0,0,0,,MCN、直播电商
Dialogue: 0,0:00:42.44,0:00:43.50,Default,,0,0,0,,如无忧和遥望
Dialogue: 0,0:00:43.50,0:00:45.17,Default,,0,0,0,,则在场控、客服、审核、
Dialogue: 0,0:00:45.17,0:00:46.99,Default,,0,0,0,,运营等环节引入AI替代
Dialogue: 0,0:00:46.99,0:00:48.65,Default,,0,0,0,,先看华策，它们大概想把
Dialogue: 0,0:00:48.65,0:00:50.32,Default,,0,0,0,,同事炼化为Skill
Dialogue: 0,0:00:50.32,0:00:52.13,Default,,0,0,0,,要求员工沉淀提示词模板
Dialogue: 0,0:00:52.13,0:00:53.95,Default,,0,0,0,,工作流资产，建立素材库
Dialogue: 0,0:00:53.95,0:00:55.77,Default,,0,0,0,,启蒙影业的AI导演等岗位
Dialogue: 0,0:00:55.77,0:00:56.98,Default,,0,0,0,,以创作执行为主
Dialogue: 0,0:00:56.98,0:00:58.18,Default,,0,0,0,,正午阳光还在试水
Dialogue: 0,0:00:58.18,0:00:59.54,Default,,0,0,0,,调研AI技术动态
Dialogue: 0,0:00:59.54,0:01:01.35,Default,,0,0,0,,提到的工具还是两年前的
Dialogue: 0,0:01:01.35,0:01:02.10,Default,,0,0,0,,与此同时
Dialogue: 0,0:01:02.10,0:01:03.46,Default,,0,0,0,,博纳已经用AI做完
Dialogue: 0,0:01:03.46,0:01:05.12,Default,,0,0,0,,《三星堆》动画大电影
Dialogue: 0,0:01:05.12,0:01:06.93,Default,,0,0,0,,他们招的全是硬核技术岗
Dialogue: 0,0:01:06.93,0:01:08.59,Default,,0,0,0,,产品经理、后端开发等
Dialogue: 0,0:01:08.59,0:01:10.39,Default,,0,0,0,,搭建起影视自动化生产线
Dialogue: 0,0:01:10.39,0:01:12.35,Default,,0,0,0,,耀客则做起了AI仿真人剧
Dialogue: 0,0:01:12.35,0:01:14.01,Default,,0,0,0,,招聘导演、抽卡师岗位
Dialogue: 0,0:01:14.01,0:01:15.67,Default,,0,0,0,,它和遥望科技都需要专门
Dialogue: 0,0:01:15.67,0:01:17.18,Default,,0,0,0,,给AI业务配备HR
Dialogue: 0,0:01:17.18,0:01:18.61,Default,,0,0,0,,柠萌影视AI岗重心
Dialogue: 0,0:01:18.61,0:01:20.04,Default,,0,0,0,,在海外油管、洋抖的
Dialogue: 0,0:01:20.04,0:01:21.95,Default,,0,0,0,,AIGC内容制作和运营
Dialogue: 0,0:01:21.95,0:01:23.86,Default,,0,0,0,,海外发行岗月薪1-2万
Dialogue: 0,0:01:23.86,0:01:25.93,Default,,0,0,0,,再来看下经纪和MCN公司
Dialogue: 0,0:01:25.93,0:01:27.68,Default,,0,0,0,,哇唧唧哇把AIGC写进
Dialogue: 0,0:01:27.68,0:01:29.27,Default,,0,0,0,,管培生要求，因为他们
Dialogue: 0,0:01:29.27,0:01:31.02,Default,,0,0,0,,让艺人跟自己的AI形象
Dialogue: 0,0:01:31.02,0:01:32.61,Default,,0,0,0,,一起走红毯、出单曲
Dialogue: 0,0:01:32.61,0:01:34.36,Default,,0,0,0,,是IP开发的重要一环
Dialogue: 0,0:01:34.36,0:01:35.49,Default,,0,0,0,,乐华娱乐则招5名
Dialogue: 0,0:01:35.49,0:01:37.18,Default,,0,0,0,,AI短视频编导，直接要求
Dialogue: 0,0:01:37.18,0:01:39.16,Default,,0,0,0,,“纯AI生成、无真人演员”
Dialogue: 0,0:01:39.16,0:01:40.58,Default,,0,0,0,,乐华五年前就已经引入
Dialogue: 0,0:01:40.58,0:01:41.57,Default,,0,0,0,,原生虚拟偶像
Dialogue: 0,0:01:41.57,0:01:43.69,Default,,0,0,0,,推出了大名鼎鼎的A-SOUL
Dialogue: 0,0:01:43.69,0:01:45.10,Default,,0,0,0,,AI大幅度降本增效
Dialogue: 0,0:01:45.10,0:01:47.08,Default,,0,0,0,,3月上新的HeyDream
Dialogue: 0,0:01:47.08,0:01:49.06,Default,,0,0,0,,采用真人脸+AI制作的模式
Dialogue: 0,0:01:49.06,0:01:50.90,Default,,0,0,0,,可以说在元宇宙里一路狂奔
Dialogue: 0,0:01:50.90,0:01:52.12,Default,,0,0,0,,艺人经纪和MCN
Dialogue: 0,0:01:52.12,0:01:53.33,Default,,0,0,0,,拥有共同的痛点
Dialogue: 0,0:01:53.33,0:01:55.01,Default,,0,0,0,,真人艺人成本和风险高
Dialogue: 0,0:01:55.01,0:01:56.53,Default,,0,0,0,,粉丝内容供给压力大
Dialogue: 0,0:01:56.53,0:01:58.35,Default,,0,0,0,,因此不约而同求助于AI
Dialogue: 0,0:01:58.35,0:01:59.87,Default,,0,0,0,,直播界巨头无忧传媒
Dialogue: 0,0:01:59.87,0:02:01.24,Default,,0,0,0,,招AI研究员岗位
Dialogue: 0,0:02:01.24,0:02:02.61,Default,,0,0,0,,要求对场控、客服、
Dialogue: 0,0:02:02.61,0:02:03.83,Default,,0,0,0,,内容审核、运营、
Dialogue: 0,0:02:03.83,0:02:05.04,Default,,0,0,0,,主播孵化等环节
Dialogue: 0,0:02:05.04,0:02:07.02,Default,,0,0,0,,输出可落地的AI替代方案
Dialogue: 0,0:02:07.02,0:02:08.54,Default,,0,0,0,,不知这一替代，又得有
Dialogue: 0,0:02:08.54,0:02:10.36,Default,,0,0,0,,多少真人岗位被释放出来？
Dialogue: 0,0:02:10.36,0:02:11.70,Default,,0,0,0,,正如小娱前阵子分析
Dialogue: 0,0:02:11.70,0:02:13.48,Default,,0,0,0,,爱优腾和B站AI岗位时候
Dialogue: 0,0:02:13.48,0:02:14.07,Default,,0,0,0,,提到的
Dialogue: 0,0:02:14.07,0:02:15.11,Default,,0,0,0,,文娱行业要么是
Dialogue: 0,0:02:15.11,0:02:16.45,Default,,0,0,0,,你让AI替你干活
Dialogue: 0,0:02:16.45,0:02:18.37,Default,,0,0,0,,要么你被AI从工位上清退
Dialogue: 0,0:02:18.37,0:02:19.56,Default,,0,0,0,,那么屏幕前的你
Dialogue: 0,0:02:19.56,0:02:20.60,Default,,0,0,0,,又是哪一种人？
Dialogue: 0,0:02:20.60,0:02:22.53,Default,,0,0,0,,你对上述哪个岗位最感兴趣
Dialogue: 0,0:02:22.53,0:02:23.56,Default,,0,0,0,,评论区聊聊吧！